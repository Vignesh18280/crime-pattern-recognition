cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/
env/
.env

# Data files (too large for GitHub)
data/
*.csv
*.tsv
*.parquet

# Model checkpoints (can be large)
*.pth
*.pt
*.ckpt

# Results (regenerated by running code)
results/
*.png

# Jupyter
.ipynb_checkpoints/
*.ipynb

# VS Code / Codespaces
.vscode/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
EOF